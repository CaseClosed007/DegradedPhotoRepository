{
  "name": "degraded-photo-detection",
  "version": "1.0.0",
  "description": "Hybrid AI pipeline to detect and restore degraded photos",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build-frontend": "cd frontend && npm install && npm run build",
    "dist": "npm run build-frontend && electron-builder --mac",
    "dist:win": "npm run build-frontend && electron-builder --win",
    "dist:linux": "npm run build-frontend && electron-builder --linux"
  },
  "build": {
    "appId": "com.nikhilsharma.degradedphotodetection",
    "productName": "Degraded Photo Detection",
    "copyright": "Nikhil Sharma",
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "dmg": {
      "title": "Degraded Photo Detection Installer",
      "window": { "width": 540, "height": 380 }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "extraResources": [
      { "from": "server.py",          "to": "server.py" },
      { "from": "clean_my_drive.py",  "to": "clean_my_drive.py" },
      { "from": "requirements.txt",   "to": "requirements.txt" },
      { "from": "src/",               "to": "src/" },
      { "from": "models/",            "to": "models/" },
      { "from": "frontend/dist/",     "to": "frontend_dist/" }
    ],
    "files": [
      "electron/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
